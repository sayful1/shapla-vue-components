{
  "name": "@shapla/vue-components",
  "description": "A collection of reusable components for Vue 3.",
  "version": "1.0.0",
  "author": {
    "name": "Sayful Islam",
    "email": "sayful.islam001@gmail.com",
    "url": "https://sayfulislam.com"
  },
  "keywords": [
    "vue",
    "vue-component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sayful1/shapla-vue-components.git"
  },
  "bugs": {
    "url": "https://github.com/sayful1/shapla-vue-components/issues"
  },
  "main": "./dist/components.umd.js",
  "module": "./dist/components.es.js",
  "unpkg": "./dist/components.umd.js",
  "exports": {
    ".": {
      "import": "./dist/components.es.js",
      "require": "./dist/components.umd.js"
    },
    "./src/index.scss": "./src/index.scss",
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist/*",
    "src/*",
    "*.json",
    "*.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build"
  },
  "peerDependencies": {
    "vue": "^3.0"
  },
  "dependencies": {
    "@shapla/vue-button": "^1.0",
    "@shapla/vue-checkbox": "^1.0",
    "@shapla/vue-chip": "^1.0",
    "@shapla/vue-columns": "^1.0",
    "@shapla/vue-confirm": "^1.0",
    "@shapla/vue-cross": "^1.0",
    "@shapla/vue-dashboard": "^1.0",
    "@shapla/vue-dropdown": "^1.0",
    "@shapla/vue-file-uploader": "^1.0",
    "@shapla/vue-icon": "^1.0",
    "@shapla/vue-image": "^1.0",
    "@shapla/vue-input": "^1.0",
    "@shapla/vue-modal": "^1.0",
    "@shapla/vue-notification": "^1.0",
    "@shapla/vue-progress": "^1.0",
    "@shapla/vue-radio": "^1.0",
    "@shapla/vue-radio-button": "^1.0",
    "@shapla/vue-select": "^1.0",
    "@shapla/vue-sidenav": "^1.0",
    "@shapla/vue-slider": "^1.0",
    "@shapla/vue-spinner": "^1.0",
    "@shapla/vue-star-rating": "^1.0",
    "@shapla/vue-switch": "^1.0",
    "@shapla/vue-table": "^1.0",
    "@shapla/vue-tabs": "^1.0",
    "@shapla/vue-toggles": "^1.0",
    "shapla-css": "^2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^1.2.2",
    "@vue/compiler-sfc": "^3.0.5",
    "autoprefixer": "^10.2.5",
    "sass": "^1.32.13",
    "vite": "^2.3.3",
    "vue": "^3.0"
  }
}
